# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (berisi API Key, Password Database, dll - BERBAHAYA JIKA DI-PUSH)
.env
.env*.local
.env.development
.env.test
.env.production

# file konfigurasi IDE lokal yang mungkin menyimpan password
.vscode/settings.json
.idea/

# file database lokal & cache (jika ada)
*.sqlite
*.db
*.db-journal

# credentials & keys
*.pem
*.key
*.crt
credentials.json
client_secret.json
# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
